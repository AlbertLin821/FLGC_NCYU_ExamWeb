# Database — Supabase / PostgreSQL
# 執行階段優先讀取 DB_URL，否則使用 DATABASE_URL（見 src/prisma/prisma.service.ts）。
#
# 本地 PostgreSQL 範例：
# DATABASE_URL="postgresql://postgres:password@localhost:5432/ncyu_exam?schema=public"
#
# Supabase + Connection Pooler（請從控制台複製，勿自行改成使用者名稱只有 postgres）：
# - Transaction（常為埠 6543）→ DATABASE_URL，須含 pgbouncer=true
# - Session（常為埠 5432）→ DIRECT_URL，供 prisma migrate / db seed
# DATABASE_URL="postgres://postgres.[PROJECT-REF]:[PASSWORD]@....pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgres://postgres.[PROJECT-REF]:[PASSWORD]@....pooler.supabase.com:5432/postgres"
DATABASE_URL="postgresql://postgres:password@localhost:5432/ncyu_exam?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/ncyu_exam?schema=public"

# JWT
JWT_SECRET="change-this-to-a-secure-random-string"
JWT_EXPIRES_IN="24h"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379

# AI APIs (fill in your keys)
OPENAI_API_KEY="sk-..."
GEMINI_API_KEY="..."
# 使用 Gemini 時的模型（預設 gemini-2.5-flash）；若遇 429／請求過於頻繁，請拉長操作間隔或升級配額
GEMINI_MODEL="gemini-2.5-flash"
AI_MODEL="gpt-4o-mini"

# Server
PORT=3000
NODE_ENV="development"
