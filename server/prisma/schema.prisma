generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============ 老師/管理者 ============
model Teacher {
  id           Int              @id @default(autoincrement())
  email        String           @unique
  passwordHash String           @map("password_hash")
  name         String
  role         String           @default("teacher") // 'admin' | 'teacher' | 'viewer'
  createdAt    DateTime         @default(now()) @map("created_at")

  classes      TeacherClass[]
  createdExams Exam[]
  createdClasses Class[]        @relation("ClassCreator")
  resolvedLogs CheatLog[]

  inviteToken   String?          @map("invite_token")
  inviteExpires DateTime?        @map("invite_expires")
  resetPasswordToken   String?   @map("reset_password_token")
  resetPasswordExpires DateTime? @map("reset_password_expires")

  @@index([role])
  @@map("teachers")
}

// ============ 班級 ============
model Class {
  id          Int              @id @default(autoincrement())
  name        String
  description String?
  createdBy   Int              @map("created_by")
  createdAt   DateTime         @default(now()) @map("created_at")

  creator     Teacher          @relation("ClassCreator", fields: [createdBy], references: [id])
  teachers    TeacherClass[]
  students    StudentClass[]
  examClasses ExamClass[]

  @@index([createdBy])
  @@map("classes")
}

// ============ 老師-班級 多對多 ============
model TeacherClass {
  teacherId Int    @map("teacher_id")
  classId   Int    @map("class_id")
  role      String @default("member") // 'owner' | 'member'

  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  class     Class   @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@id([teacherId, classId])
  @@index([classId])
  @@map("teacher_classes")
}

// ============ 學生 ============
model Student {
  id            Int       @id @default(autoincrement())
  studentId     String    @unique @map("student_id")
  name          String
  schoolName    String    @default("國立嘉義大學") @map("school_name")
  loginAttempts Int       @default(0) @map("login_attempts")
  lockedUntil   DateTime? @map("locked_until")
  createdAt     DateTime  @default(now()) @map("created_at")

  classes       StudentClass[]
  sessions      ExamSession[]

  @@map("students")
}

// ============ 學生-班級 多對多 ============ 
model StudentClass {
  studentId Int @map("student_id")
  classId   Int @map("class_id")

  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class     Class   @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@id([studentId, classId])
  @@index([classId])
  @@map("student_classes")
}

// ============ 考卷 ↔ 班級（多對多） ============
model ExamClass {
  examId  Int @map("exam_id")
  classId Int @map("class_id")

  exam  Exam  @relation(fields: [examId], references: [id], onDelete: Cascade)
  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@id([examId, classId])
  @@index([classId])
  @@map("exam_classes")
}

// ============ 考卷 ============
model Exam {
  id         Int       @id @default(autoincrement())
  title      String
  difficulty String?   // 'easy' | 'medium' | 'hard'
  timeLimit  Int       @map("time_limit") // 分鐘
  startTime  DateTime  @map("start_time")
  endTime    DateTime  @map("end_time")
  status     String    @default("draft") // 'draft' | 'published' | 'closed'
  createdBy  Int       @map("created_by")
  createdAt  DateTime  @default(now()) @map("created_at")
  deletedAt  DateTime? @map("deleted_at")

  examClasses ExamClass[]
  creator     Teacher     @relation(fields: [createdBy], references: [id])
  questions   Question[]
  sessions    ExamSession[]

  @@index([status])
  @@index([startTime, endTime])
  @@index([createdBy])
  @@map("exams")
}

// ============ 題目 ============
model Question {
  id       Int      @id @default(autoincrement())
  examId   Int      @map("exam_id")
  type     String   @default("multiple_choice") // 'multiple_choice', 'multiple_selection', 'essay'
  content  String?  // Question text / prompt
  options  Json?    // Optional for selection types [{ label: 'A', text: '...' }]
  answer   String?  // Correct answer string or sample answer
  word1    String?  // Existing field for sentence building
  word2    String?  // Existing field for sentence building
  orderNum Int      @map("order_num")
  maxPoints Int     @default(100) @map("max_points")

  exam     Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  answers  Answer[]

  @@index([examId])
  @@map("questions")
}

// ============ 考試作答 Session ============
model ExamSession {
  id          Int       @id @default(autoincrement())
  studentId   Int       @map("student_id")
  examId      Int       @map("exam_id")
  status      String    @default("pending") // pending | in_progress | paused | submitted | graded
  startedAt   DateTime? @map("started_at")
  submittedAt DateTime? @map("submitted_at")
  /** 有非空白作答內容的題目數；列表／監看端可讀此欄，避免每筆都 JOIN answers 即時 COUNT */
  answeredQuestionCount Int @default(0) @map("answered_question_count")
  overallFeedbackEn String? @map("overall_feedback_en") @db.Text
  overallFeedbackZh String? @map("overall_feedback_zh") @db.Text

  student     Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  exam        Exam       @relation(fields: [examId], references: [id], onDelete: Cascade)
  answers     Answer[]
  cheatLogs   CheatLog[]

  @@unique([studentId, examId])
  @@index([status])
  @@index([examId, status])
  @@index([studentId])
  @@index([submittedAt])
  @@map("exam_sessions")
}

// ============ 答案 ============
model Answer {
  id         Int      @id @default(autoincrement())
  sessionId  Int      @map("session_id")
  questionId Int      @map("question_id")
  content    String?  // Student's answer (sentence or selected option(s))
  aiScore    Decimal? @map("ai_score") @db.Decimal(5, 2)
  aiFeedback String?  @map("ai_feedback")
  aiModel    String?  @map("ai_model")
  writingDurationSeconds Int? @map("writing_duration_seconds")
  wordCount Int? @map("word_count")
  writingScore Decimal? @map("writing_score") @db.Decimal(4, 2)
  cefrLevel String? @map("cefr_level")
  createdAt  DateTime @default(now()) @map("created_at")

  session    ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question   Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionId])
  @@map("answers")
}

// ============ 防弊紀錄 ============
model CheatLog {
  id         Int       @id @default(autoincrement())
  sessionId  Int       @map("session_id")
  eventType  String    @map("event_type") // 'tab_switch' | 'window_blur' | 'fullscreen_exit'
  details    Json?
  resolvedBy Int?      @map("resolved_by")
  resolution String?   // 'unlocked' | 'terminated'
  createdAt  DateTime  @default(now()) @map("created_at")

  session    ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  resolver   Teacher?    @relation(fields: [resolvedBy], references: [id])

  @@index([sessionId])
  @@index([eventType])
  @@index([resolvedBy])
  @@map("cheat_logs")
}
